# ── KineticAI Backend Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.

# Gemini API key — get yours free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_KEY_HERE

# Flask secret key — change this to a long random string in production
SECRET_KEY=YOUR_KEY_HERE

# Path to the SQLite database file (defaults to instance/workout_app.db)
# DB_PATH=instance/workout_app.db
